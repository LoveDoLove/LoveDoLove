---
const USERNAME = "LoveDoLove";
---

<section class="card stats">
  <h2>GitHub Stats</h2>
  <div class="stat-grid">
    <img
      src={`https://personal-trophy.vercel.app/api?username=${USERNAME}&theme=dark`}
      alt="GitHub Trophy"
      loading="lazy"
      class="stat-img"
    />
    <img
      src={`https://github-stats-extended.vercel.app/api?username=${USERNAME}&show_icons=true&theme=gruvbox`}
      alt="GitHub Stats"
      loading="lazy"
      class="stat-img"
    />
    <img
      src={`https://github-stats-extended.vercel.app/api/top-langs/?username=${USERNAME}&layout=compact&theme=gruvbox`}
      alt="Top Languages"
      loading="lazy"
      class="stat-img"
    />
    <img
      src={`https://github-stats-extended.vercel.app/api/wakatime?username=${USERNAME}&theme=gruvbox`}
      alt="WakaTime Stats"
      loading="lazy"
      class="stat-img"
    />
    <img
      src={`https://komarev.com/ghpvc/?username=${USERNAME}&color=blue`}
      alt="Profile Views"
      loading="lazy"
      class="stat-img"
    />
  </div>
</section>

<style>
  .stats {
    display: flex;
    flex-direction: column;
  }
  .stats h2 {
    margin-bottom: 6px;
  }
  .stats-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .stat-img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    display: block;
    max-height: 180px;
  }
</style>